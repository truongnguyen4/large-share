<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:padding="16dp"
    android:orientation="vertical"

    tools:context=".MainActivity">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LargeShare P2P (BitTorrent style)"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Section 1: Discovery Mechanism & Mode selectors -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Protocol &amp; Role Setup"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discovery Protocol:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#555555"/>

                <RadioGroup
                    android:id="@+id/rg_discovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rb_nsd"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NSD"/>

                    <RadioButton
                        android:id="@+id/rb_wifidirect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wi-Fi Direct"/>
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Role:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#555555"/>

                <RadioGroup
                    android:id="@+id/rg_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rb_root"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Root"/>

                    <RadioButton
                        android:id="@+id/rb_seeker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Seeker"/>
                </RadioGroup>

                <!-- Custom File Selector for Root Device -->
                <LinearLayout
                    android:id="@+id/ll_file_picker_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Root Data Payload:"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btn_select_file"
                            style="?android:attr/buttonStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select File"
                            android:backgroundTint="#00897B"
                            android:textColor="#FFFFFF"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tv_selected_file_info"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Selected file: None"
                            android:textSize="12sp"
                            android:textColor="#424242"
                            android:textStyle="italic"/>
                    </LinearLayout>

                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="8dp"
                        android:background="#F5F5F5">

                        <TextView
                            android:id="@+id/tv_metadata_details"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:text="No metadata compiled yet. Select a file or use the default to split &amp; build the chunk SHA-256 table."
                            android:textSize="11sp"
                            android:textColor="#47525E"
                            android:fontFamily="monospace"
                            android:visibility="visible"/>
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 2: Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_distribute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Distribute Data"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_retry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Retry Failures"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:visibility="gone"
                android:enabled="false"/>

        </LinearLayout>

        <!-- Section 3: Local Node Progress -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Local Node Information"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_node_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Node ID: N/A"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chunks: 0 / 0 (0.00%)"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="6dp"/>

                <ProgressBar
                    android:id="@+id/pb_download"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:max="100"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tv_failure_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Failed Chunks Log: None"
                    android:textColor="#D32F2F"
                    android:textSize="13sp"
                    android:textStyle="italic"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 4: Peers Progress Tracker (Root perspective) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_peers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Network Peers Progress Tracker"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_peers_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No peers connected yet."
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:minLines="3"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 5: Operation Logs -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. Operating System Status Log"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tv_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#ECEFF1"
                    android:padding="8dp"
                    android:scrollbars="vertical"
                    android:text="Service offline\n"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#37474F"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

</LinearLayout>
</androidx.core.widget.NestedScrollView>
