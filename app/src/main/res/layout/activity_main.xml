<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:padding="16dp"
    android:orientation="vertical"

    tools:context=".MainActivity">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LargeShare P2P (BitTorrent style)"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Section 1: Discovery Mechanism & Mode selectors -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Protocol &amp; Role Setup"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discovery Protocol:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#555555"/>

                <RadioGroup
                    android:id="@+id/rg_discovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rb_nsd"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NSD"/>

                    <RadioButton
                        android:id="@+id/rb_wifidirect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Wi-Fi Direct"/>
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Role:"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#555555"/>

                <RadioGroup
                    android:id="@+id/rg_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <RadioButton
                        android:id="@+id/rb_root"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Root"/>

                    <RadioButton
                        android:id="@+id/rb_seeker"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Seeker"/>
                </RadioGroup>

                <!-- Custom File Selector for Root Device -->
                <LinearLayout
                    android:id="@+id/ll_file_picker_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Root Data Payload:"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="4dp"/>

                    <Button
                        android:id="@+id/btn_select_file"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select File"
                        android:backgroundTint="#00897B"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="8dp"/>

                    <!-- Collapsible card: header shows the selected file, body shows metadata -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#F5F5F5">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Header: tap to expand/collapse the metadata body -->
                            <LinearLayout
                                android:id="@+id/ll_file_card_header"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="?android:attr/selectableItemBackground"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/tv_selected_file_info"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Selected file: None"
                                    android:textSize="12sp"
                                    android:textColor="#424242"
                                    android:textStyle="italic"/>

                                <TextView
                                    android:id="@+id/tv_file_card_toggle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="▸"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#1976D2"
                                    android:paddingStart="8dp"/>
                            </LinearLayout>

                            <!-- Collapsible body: chunk / SHA-256 metadata -->
                            <androidx.core.widget.NestedScrollView
                                android:id="@+id/nsv_metadata_details"
                                android:layout_width="match_parent"
                                android:layout_height="150dp"
                                android:background="#FFFFFF"
                                android:visibility="gone">

                                <TextView
                                    android:id="@+id/tv_metadata_details"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:padding="8dp"
                                    android:text="No metadata compiled yet. Select a file or use the default to split &amp; build the chunk SHA-256 table."
                                    android:textSize="11sp"
                                    android:textColor="#47525E"
                                    android:fontFamily="monospace"/>
                            </androidx.core.widget.NestedScrollView>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 2: Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_distribute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Distribute Data"
                android:backgroundTint="#1976D2"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"/>

        </LinearLayout>

        <!-- Section 3: My Download Progress (Seeker perspective) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_seeker_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Download Progress"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1976D2"/>

                    <TextView
                        android:id="@+id/tv_seeker_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_seeker"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tv_seeker_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting to leech chunks…"
                    android:textSize="13sp"
                    android:textColor="#333333"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 4: Peers Progress Tracker (Root perspective) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cv_peers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:elevation="4dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2. Network Peers Progress Tracker"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1976D2"/>

                    <TextView
                        android:id="@+id/tv_peers_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 peers"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#00897B"/>
                </LinearLayout>

                <!-- Peer filter: autocomplete search + tick-to-select dialog -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">



                    <Button
                        android:id="@+id/btn_peer_filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select"
                        android:backgroundTint="#00897B"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tv_peer_filter_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Showing all peers"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:textColor="#00897B"/>

                    <TextView
                        android:id="@+id/tv_peer_filter_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show all ✕"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#D32F2F"
                        android:padding="4dp"
                        android:visibility="gone"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_peers_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No peers connected yet."
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:textStyle="italic"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_peers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Shown when this device finishes downloading. -->
        <TextView
            android:id="@+id/tv_completion_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:padding="12dp"
            android:text="Download complete. Staying online briefly to keep sharing chunks with peers…"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone"/>

</LinearLayout>
</androidx.core.widget.NestedScrollView>
